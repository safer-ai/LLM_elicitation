# Copy this file to `.env` (in this repo root) and fill in real keys.
# The actual `.env` file is gitignored.
#
# API key resolution order (highest priority first), per src/config.py:
#   1. KEY=VALUE in <repo_root>/.env (this file).
#   2. Process environment variable.
#
# API keys are NOT read from the YAML config. config.py logs which source was
# used and the first 14 chars of the key, so you can confirm at runtime which
# account is being charged.

ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

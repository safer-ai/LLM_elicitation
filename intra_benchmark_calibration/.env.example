# Copy this file to `.env` (in this directory or in the repo root) and fill in
# real keys. The actual `.env` is gitignored.
#
# Resolution order (highest priority first):
#   1. `anthropic_api_key:` / `openai_api_key:` in the YAML config 
#   2. process environment variable
#   3. KEY=VALUE in intra_benchmark_calibration/.env
#   4. KEY=VALUE in LLM_elicitation/.env (repo root)
#
# config.py logs which source was used and the first 14 chars of the key, so
# you can confirm which account is paying for the run.
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...

# Copy this file to `.env` (in this directory or in the repo root) and fill in
# real keys. The actual `.env` is gitignored.
#
# Resolution order (highest priority first):
#   1. KEY=VALUE in intra_benchmark_calibration/.env  (project-local)
#   2. KEY=VALUE in LLM_elicitation/.env              (repo root)
#   3. process environment variable
#
# API keys are NOT read from the YAML config; specifying them there is an
# error. config.py logs which source was used and the first 14 chars of the
# key, so you can confirm which account is paying for the run.
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
